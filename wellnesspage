<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --cream: #ffffff;
    --soft-white: #f8fafb;
    --blush: #e0f2f1;
    --rose: #b2dfdb;
    --dusty-rose: #26a69a;
    --mauve: #00897b;
    --deep-rose: #00695c;
    --sage: #4db6ac;
    --soft-sage: #80cbc4;
    --mint: #e0f2f1;
    --aqua: #80cbc4;
    --teal: #26a69a;
    --deep-teal: #00695c;
    --charcoal: #263238;
    --warm-grey: #546e7a;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Montserrat', sans-serif;
    background: var(--cream);
    color: var(--charcoal);
    overflow-x: hidden;
    line-height: 1.6;
  }

  /* ─── HERO ─── */
  .hero {
    min-height: 100vh;
    display: grid; 
    grid-template-columns: 1fr 1fr; 
    align-items: center;
    padding: 5rem 4rem;
    background: linear-gradient(135deg, #f4e8e3 0%, #e8f3f1 50%, #c9d5c8 100%);
    position: relative; 
    overflow: hidden;
  }
  .hero::before {
    content: ''; 
    position: absolute; 
    top: -150px; 
    right: -150px;
    width: 700px; 
    height: 700px; 
    border-radius: 50%; 
    background: radial-gradient(circle, rgba(38,166,154,0.08) 0%, transparent 70%);
  }
  .hero::after {
    content: ''; 
    position: absolute; 
    bottom: -200px; 
    left: -100px;
    width: 600px; 
    height: 600px; 
    border-radius: 50%; 
    background: radial-gradient(circle, rgba(0,105,92,0.05) 0%, transparent 70%);
  }
  .hero-content { position: relative; z-index: 2; max-width: 600px; }
  
  /* Logo */
  .logo-container {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  
  .logo-svg {
    width: 80px;
    height: 80px;
  }
  
  .logo-text h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem;
    font-weight: 400;
    color: var(--deep-teal);
    margin: 0;
    line-height: 1.1;
  }
  
  .logo-text p {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--teal);
    margin: 0.3rem 0 0 0;
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--teal);
    display: block;
    margin-bottom: 1rem;
  }

  .hero h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3.8rem;
    font-weight: 300;
    color: var(--charcoal);
    margin-bottom: 1.5rem;
    line-height: 1.1;
  }
  .hero h2 em { font-style: italic; font-weight: 400; color: var(--deep-teal); }

  .hero p {
    font-size: 1.05rem;
    font-weight: 300;
    line-height: 1.8;
    color: var(--warm-grey);
    margin-bottom: 2.5rem;
  }

  .btn-primary {
    display: inline-block;
    background: linear-gradient(135deg, var(--dusty-rose), var(--mauve));
    color: white;
    padding: 1.1rem 2.8rem;
    border-radius: 50px;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    box-shadow: 0 6px 25px rgba(38,166,154,0.25);
    text-transform: uppercase;
  }
  .btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 35px rgba(38,166,154,0.35);
    background: linear-gradient(135deg, var(--mauve), var(--deep-rose));
  }

  .hero-media { position: relative; z-index: 2; }
  .hero-media img {
    width: 100%;
    max-width: 500px;
    height: auto;
    border-radius: 20px;
    box-shadow: 0 25px 60px rgba(0,0,0,0.15);
    margin-left: auto;
    display: block;
  }

  /* ─── SECTIONS ─── */
  section {
    padding: 6rem 4rem;
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
  }

  .section-label {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--teal);
    text-align: center;
    margin-bottom: 0.8rem;
  }

  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3rem;
    font-weight: 300;
    text-align: center;
    color: var(--charcoal);
    margin-bottom: 1rem;
  }
  .section-title em { font-style: italic; color: var(--deep-teal); font-weight: 400; }

  .divider {
    width: 80px;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--teal), transparent);
    margin: 0 auto 3rem;
  }

  .section-body {
    font-size: 1.05rem;
    line-height: 1.9;
    color: var(--warm-grey);
    max-width: 760px;
    margin: 0 auto 3rem;
    text-align: center;
    font-weight: 300;
  }

  /* ─── SCIENCE ─── */
  #science {
    background: var(--charcoal);
    color: white;
    padding: 6rem 4rem;
  }
  #science .section-label { color: var(--soft-sage); }
  #science .section-title { color: white; }
  #science .section-title em { color: var(--soft-sage); }
  #science .section-body { color: rgba(255,255,255,0.8); }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2.5rem;
    margin-top: 3rem;
  }

  .benefit-card {
    background: rgba(255,255,255,0.05);
    backdrop-filter: blur(10px);
    padding: 2.5rem 2rem;
    border-radius: 16px;
    border: 1px solid rgba(255,255,255,0.1);
    transition: all 0.4s ease;
  }

  .benefit-card:hover {
    background: rgba(255,255,255,0.08);
    transform: translateY(-5px);
    border-color: var(--soft-sage);
  }

  .benefit-icon {
    margin-bottom: 1.5rem;
  }

  .benefit-card h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.7rem;
    font-weight: 400;
    color: var(--soft-sage);
    margin-bottom: 1rem;
  }

  .benefit-card p {
    font-size: 0.95rem;
    line-height: 1.8;
    color: rgba(255,255,255,0.75);
    font-weight: 300;
  }

  /* ─── PRODUCTS ─── */
  #products { 
    background: linear-gradient(135deg, var(--sage) 0%, var(--teal) 100%);
  }
  #products .section-label { color: var(--mint); }
  #products .section-title { color: #fff; }
  #products .section-title em { color: var(--mint); }
  #products .section-body { color: rgba(255,255,255,0.85); }
  #products .divider { 
    background: linear-gradient(to right, var(--mint), rgba(255,255,255,0.3)); 
  }
  .products-intro { 
    max-width: 650px; 
    margin-bottom: 4rem; 
  }

  /* ─── PRODUCT ROWS ─── */
  .product-row {
    background: rgba(255,255,255,0.1);
    border-radius: 20px; 
    border: 1px solid rgba(255,255,255,0.2);
    padding: 2.5rem; 
    margin-bottom: 2rem;
    transition: all 0.3s;
    backdrop-filter: blur(10px);
  }
  .product-row:hover { 
    background: rgba(255,255,255,0.15); 
    box-shadow: 0 15px 45px rgba(0,0,0,0.2); 
  }

  .product-row-header {
    display: flex; 
    align-items: center; 
    gap: 1.5rem;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(255,255,255,0.15);
  }
  .product-row-icon { font-size: 2.5rem; }
  .product-row-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem; 
    color: #fff; 
    margin-top: 0.3rem;
    font-weight: 300;
  }

  .product-tag {
    display: inline-block; 
    font-size: 0.65rem; 
    letter-spacing: 0.15em;
    text-transform: uppercase; 
    padding: 0.3rem 0.8rem;
    background: rgba(255,255,255,0.2); 
    color: #fff; 
    border-radius: 20px;
    margin-bottom: 0.5rem;
    font-weight: 500;
  }

  .product-row-body {
    display: grid; 
    grid-template-columns: 1fr 1fr; 
    gap: 3rem; 
    align-items: start;
  }
  .product-row-text p {
    font-size: 0.95rem; 
    color: rgba(255,255,255,0.85); 
    line-height: 2; 
    font-weight: 300;
    margin-bottom: 1.5rem;
  }
  .product-benefits {
    list-style: none;
    margin-top: 1rem;
  }
  .product-benefits li {
    font-size: 0.88rem;
    color: rgba(255,255,255,0.8);
    padding: 0.4rem 0;
    padding-left: 1.5rem;
    position: relative;
    font-weight: 300;
  }
  .product-benefits li::before {
    content: '✧';
    position: absolute;
    left: 0;
    color: var(--mint);
    font-size: 0.7rem;
    top: 0.6rem;
  }

  /* ─── DOWNLOADS ─── */
  #downloads {
    background: var(--cream);
  }
  .download-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 3rem;
  }
  .download-card {
    background: var(--soft-white);
    border-radius: 15px;
    padding: 2.5rem;
    text-decoration: none;
    transition: all 0.3s;
    border: 1px solid var(--rose);
    box-shadow: 0 4px 20px rgba(0,0,0,0.03);
  }
  .download-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 35px rgba(157,113,113,0.15);
    border-color: var(--dusty-rose);
  }
  .download-icon {
    font-size: 2.5rem;
    display: block;
    margin-bottom: 1.2rem;
  }
  .download-card h4 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem;
    color: var(--charcoal);
    margin-bottom: 0.8rem;
    font-weight: 400;
  }
  .download-card p {
    font-size: 0.85rem;
    color: var(--warm-grey);
    line-height: 1.8;
    margin-bottom: 1.5rem;
    font-weight: 300;
  }
  .download-label {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--deep-rose);
    font-weight: 500;
  }

  /* ─── VIDEO THUMBNAILS ─── */
  .video-thumbnail {
    border-radius: 20px;
    aspect-ratio: 16/9;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #26a69a 0%, #00897b 50%, #00695c 100%);
  }

  .video-thumbnail::before {
    content: '';
    position: absolute;
    top: -150px;
    right: -150px;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
  }

  .video-thumbnail::after {
    content: '';
    position: absolute;
    bottom: -120px;
    left: -80px;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(0,0,0,0.2) 0%, transparent 70%);
  }

  .video-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 2rem;
  }

  .video-thumbnail h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.5rem;
    color: #fff;
    margin: 0 0 0.8rem 0;
    font-weight: 300;
    text-shadow: 0 2px 8px rgba(0,0,0,0.4);
    line-height: 1.2;
  }

  .video-thumbnail p {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.85);
    margin: 0;
    text-shadow: 0 1px 3px rgba(0,0,0,0.3);
  }

  /* ─── BUSINESS ─── */
  #business {
    background: linear-gradient(135deg, var(--deep-teal) 0%, var(--mauve) 100%);
    color: white;
  }
  #business .section-label { color: var(--mint); }
  #business .section-title { color: white; }
  #business .section-title em { color: var(--mint); }
  #business .section-body { color: rgba(255,255,255,0.85); }

  .business-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2.5rem;
    margin-top: 3rem;
  }

  .business-card {
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(10px);
    padding: 2.5rem 2rem;
    border-radius: 16px;
    border: 1px solid rgba(255,255,255,0.15);
    transition: all 0.4s ease;
    text-align: center;
  }

  .business-card:hover {
    background: rgba(255,255,255,0.15);
    transform: translateY(-5px);
    border-color: var(--mint);
  }

  .business-card-icon {
    margin: 0 auto 1.5rem;
    display: block;
  }

  .business-card h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.6rem;
    font-weight: 400;
    color: var(--mint);
    margin-bottom: 1rem;
  }

  .business-card p {
    font-size: 0.95rem;
    line-height: 1.8;
    color: rgba(255,255,255,0.8);
    font-weight: 300;
  }

  /* ─── CONTACT ─── */
  #contact {
    background: var(--soft-white);
    text-align: center;
  }

  .cta-options {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 2.5rem;
  }

  /* ─── FOOTER ─── */
  footer {
    background: var(--charcoal);
    color: rgba(255,255,255,0.6);
    text-align: center;
    padding: 3rem 2rem;
    font-size: 0.85rem;
  }
  footer span { color: var(--soft-sage); }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      padding: 3rem 2rem;
      text-align: center;
    }
    .hero-content { max-width: 100%; }
    .hero h2 { font-size: 2.8rem; }
    .hero-media img { margin: 3rem auto 0; max-width: 400px; }
    .logo-container { justify-content: center; }
    section { padding: 4rem 2rem; }
    .section-title { font-size: 2.2rem; }
    .product-grid, .benefits-grid, .business-grid, .experience-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .product-row {
      padding: 2rem 1.5rem;
      margin-bottom: 2.5rem;
    }
    .product-row-header {
      flex-direction: column;
      text-align: center;
      gap: 1rem;
    }
    .product-row-body {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .product-row-text p {
      text-align: center;
    }
    #other-products {
      padding: 4rem 2rem 6rem !important;
    }
    .download-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
</head>

<body>

<!-- HERO -->
<section class="hero">
  <div class="hero-content">
    <span class="eyebrow">Welcome Back</span>
    <h2>Bring Home the Water <em>You Discovered</em></h2>
    <p>You've experienced the difference at our centre. Now you can enjoy that same premium Kangen Water® — fresh, alkaline, and hydrogen-rich — every day in your own home.</p>
  </div>
  <div class="hero-media">
    <svg viewBox="0 0 500 500" xmlns="http://www.w3.org/2000/svg" style="width: 100%; max-width: 500px; height: auto; border-radius: 20px; box-shadow: 0 25px 60px rgba(0,0,0,0.15); margin-left: auto; display: block;">
      <!-- Gradient Background -->
      <defs>
        <linearGradient id="bgGradient" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#e8f3f1;stop-opacity:1" />
          <stop offset="50%" style="stop-color:#b2dfdb;stop-opacity:1" />
          <stop offset="100%" style="stop-color:#80cbc4;stop-opacity:1" />
        </linearGradient>
        <linearGradient id="dropletGradient" x1="0%" y1="0%" x2="0%" y2="100%">
          <stop offset="0%" style="stop-color:#80cbc4;stop-opacity:1" />
          <stop offset="100%" style="stop-color:#26a69a;stop-opacity:1" />
        </linearGradient>
        <radialGradient id="glowGradient" cx="50%" cy="50%">
          <stop offset="0%" style="stop-color:#ffffff;stop-opacity:0.4" />
          <stop offset="100%" style="stop-color:#ffffff;stop-opacity:0" />
        </radialGradient>
      </defs>
      
      <!-- Background -->
      <rect width="500" height="500" fill="url(#bgGradient)"/>
      
      <!-- Decorative circles - background -->
      <circle cx="100" cy="100" r="80" fill="#26a69a" opacity="0.08"/>
      <circle cx="420" cy="400" r="120" fill="#00897b" opacity="0.06"/>
      <circle cx="380" cy="120" r="60" fill="#4db6ac" opacity="0.07"/>
      
      <!-- Main water droplet -->
      <g transform="translate(250, 200)">
        <!-- Shadow -->
        <ellipse cx="0" cy="100" rx="90" ry="20" fill="#000000" opacity="0.1"/>
        
        <!-- Main droplet shape -->
        <path d="M 0,-120 C -50,-60 -80,-20 -80,20 C -80,75 -45,110 0,110 C 45,110 80,75 80,20 C 80,-20 50,-60 0,-120 Z" 
              fill="url(#dropletGradient)" 
              stroke="#00695c" 
              stroke-width="2" 
              opacity="0.95"/>
        
        <!-- Light reflection on droplet -->
        <ellipse cx="-25" cy="-40" rx="30" ry="50" fill="url(#glowGradient)"/>
        <ellipse cx="-20" cy="-30" rx="18" ry="28" fill="#ffffff" opacity="0.6"/>
        <ellipse cx="-15" cy="-25" rx="8" ry="12" fill="#ffffff" opacity="0.9"/>
        
        <!-- Ripple rings below -->
        <g transform="translate(0, 110)">
          <circle cx="0" cy="0" r="100" fill="none" stroke="#26a69a" stroke-width="2" opacity="0.3"/>
          <circle cx="0" cy="0" r="125" fill="none" stroke="#26a69a" stroke-width="1.5" opacity="0.2"/>
          <circle cx="0" cy="0" r="150" fill="none" stroke="#26a69a" stroke-width="1" opacity="0.1"/>
        </g>
        
        <!-- Small accent bubbles -->
        <circle cx="-50" cy="-80" r="8" fill="#ffffff" opacity="0.4"/>
        <circle cx="45" cy="-70" r="6" fill="#ffffff" opacity="0.3"/>
        <circle cx="-35" cy="-100" r="5" fill="#ffffff" opacity="0.35"/>
        <circle cx="30" cy="-95" r="7" fill="#ffffff" opacity="0.3"/>
      </g>
      
      <!-- Brand text -->
      <text x="250" y="420" font-family="'Cormorant Garamond', serif" font-size="42" font-weight="400" fill="#00695c" text-anchor="middle" letter-spacing="1">Vitality Springs</text>
      <text x="250" y="450" font-family="'Montserrat', sans-serif" font-size="14" font-weight="400" fill="#26a69a" text-anchor="middle" letter-spacing="6" text-transform="uppercase">WELLNESS CENTRE</text>
      
      <!-- Decorative line under text -->
      <line x1="150" y1="465" x2="350" y2="465" stroke="#26a69a" stroke-width="1" opacity="0.3"/>
    </svg>
  </div>
</section>

<!-- SCIENCE -->
